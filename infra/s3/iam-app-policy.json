{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SpiderSilkAppReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::spidersilk-app-spidersilk-processed-files/processed/*",
        "arn:aws:s3:::spidersilk-app-spidersilk-processed-files/records/*"
      ]
    },
    {
      "Sid": "SpiderSilkAppListBucket",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::spidersilk-app-spidersilk-processed-files",
      "Condition": {
        "StringLike": { "s3:prefix": ["processed/*", "records/*"] }
      }
    }
  ]
}
